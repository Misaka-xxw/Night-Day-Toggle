{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "night-day-toggle",
  "version": "0.1.0",
  "identifier": "com.misaka-xxw.night-day-toggle",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "主题切换悬浮球",
        "width": 80,
        "height": 80,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "focus": false,
        "shadow": false,
        "url": "index.html",
        "dragDropEnabled": true,
        "focusable": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}